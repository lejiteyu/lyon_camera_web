<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- Selection UI -->
    <LinearLayout
        android:id="@+id/selectionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lyon WebCam"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnStartServer"
            android:layout_width="240dp"
            android:layout_height="64dp"
            android:text="Start Viewer (Server)"
            android:layout_marginBottom="16dp"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnJoinAsCamera"
            android:layout_width="240dp"
            android:layout_height="64dp"
            android:text="Join as Camera"
            style="@style/Widget.Material3.Button.TonalButton"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Viewer UI -->
    <LinearLayout
        android:id="@+id/viewerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">
            <TextView
                android:id="@+id/txtServerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Waiting for connections..."
                android:textColor="#BBFFFFFF" />
            
            <LinearLayout
                android:id="@+id/layoutLiveIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">
                <View
                    android:id="@+id/viewLiveDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@android:drawable/presence_online"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp">

            <GridLayout
                android:id="@+id/gridVideoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:padding="8dp" />
        </ScrollView>
    </LinearLayout>

    <!-- Full Screen View -->
    <ImageView
        android:id="@+id/imgFullScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnCloseFullScreen"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#FFFFFF" />

    <!-- Camera UI -->
    <FrameLayout
        android:id="@+id/cameraLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/txtClientStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discovering server..."
            android:textColor="#BBFFFFFF"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="16dp"
            android:background="#88000000"
            android:padding="8dp"/>

        <ImageButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="32dp"
            android:background="@drawable/ic_circle_button"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#FFFFFF" />

        <Button
            android:id="@+id/btnReconnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="32dp"
            android:text="Retry"
            app:cornerRadius="8dp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
